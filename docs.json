{
  "$schema": "https://mintlify.com/schema.json",
  "name": "ZeroDrop",
  "theme": "mint",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#00ff88",
    "light": "#00ff88",
    "dark": "#00cc6a"
  },
  "topbarLinks": [
    {
      "name": "zerodrop.dev",
      "url": "https://zerodrop.dev"
    }
  ],
  "topbarCtaButton": {
    "name": "Get Started Free",
    "url": "https://zerodrop.dev"
  },
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/zerodrop-dev"
    },
    {
      "name": "npm",
      "icon": "npm",
      "url": "https://npmjs.com/package/zerodrop-client"
    },
    {
      "name": "Status",
      "icon": "signal",
      "url": "https://zerodrop.instatus.com"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["quickstart"]
          },
          {
            "group": "Frameworks",
            "pages": ["playwright", "cypress"]
          },
          {
            "group": "CI/CD",
            "pages": [
              {
                "page": "github-actions",
                "title": "GitHub Actions"
              }
            ]
          },
          {
            "group": "Reference",
            "pages": [
              {
                "page": "sdk-reference",
                "title": "SDK Reference"
              },
              {
                "page": "self-hosting",
                "title": "Self-Hosting"
              }
            ]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "twitter": "https://x.com/zerodropdev",
    "github": "https://github.com/zerodrop-dev"
  }
}
